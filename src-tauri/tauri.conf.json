{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReMap",
  "version": "0.1.0",
  "identifier": "com.yvig.remap",
  "build": {
    "beforeDevCommand": "node ./node_modules/vite/bin/vite.js",
    "beforeBuildCommand": "node ./node_modules/vite/bin/vite.js build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ReMap",
        "width": 1320,
        "height": 880,
        "minWidth": 820,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
